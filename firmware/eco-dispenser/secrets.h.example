// secrets.h — copie este arquivo para secrets.h e preencha os campos.
// secrets.h está no .gitignore e nunca é commitado.
#ifndef SECRETS_H
#define SECRETS_H

// Credenciais WiFi.
// Deixe ambos vazios ("") para ativar o provisionamento via BLE na primeira inicialização.
// Após o provisionamento, as credenciais ficam salvas na NVS e este arquivo não é mais usado.
const char* WIFI_SSID     = "";  // ex: "MinhaRede"
const char* WIFI_PASSWORD = "";  // ex: "minhasenha123"

// URL base do backend (sem trailing slash).
// Usada para enviar o heartbeat ao conectar ao WiFi.
// Deixe vazio ("") para desabilitar.
const char* BACKEND_URL   = "";  // ex: "https://pill.josoesantos.dev" (fallback se NVS vazia)

#endif
