# Cloudflare API token (DNS edit) — certificado SSL automático no Caddy
# Crie em: Cloudflare Dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=

# Origens CORS extras para o backend (separadas por vírgula, opcional)
# CORS_ORIGINS=https://outro-dominio.example

# URL enviada ao ESP32 no pareamento BLE (heartbeat)
# Produção: domínio público HTTPS (Caddy → nginx → /api)
# Alternativa: http://SEU_SERVIDOR:8001 (API direta, sem TLS no ESP)
VITE_ESP_BACKEND_URL=https://pill.josoesantos.dev
