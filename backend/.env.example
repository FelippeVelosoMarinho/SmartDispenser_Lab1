# ESP32-C3 IP address on the local network
ESP32_IP=192.168.109.25

# Period dispense times (HH:MM) — used as defaults when no UI schedule saved
DISPENSE_PERIOD_MORNING=21:00
DISPENSE_PERIOD_AFTERNOON=21:01
DISPENSE_PERIOD_NIGHT=21:02

# Scheduler tuning (seconds)
SCHEDULER_POLL_SECONDS=10
SCHEDULER_DUE_WINDOW_SECONDS=45
SCHEDULER_AWAITING_CONFIRM_GRACE_SECONDS=120
# Laboratório: true só com firmware REQUIRE_PATIENT_CONFIRM=0
SCHEDULER_IGNORE_AWAITING_CONFIRM=false
SCHEDULER_DEDUP_SECONDS=90

# queue = ESP pulls commands via heartbeat (cloud/LAN); push = direct POST /dispense (LAN dev only)
SCHEDULER_MODE=queue
COMMAND_ACK_TIMEOUT_SECONDS=900

# IANA timezone for period schedules (HH:MM). Must match caregiver local time.
SCHEDULER_TIMEZONE=America/Sao_Paulo
