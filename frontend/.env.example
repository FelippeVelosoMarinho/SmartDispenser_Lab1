# URL que o ESP32 recebe no pareamento BLE (heartbeat, scheduler).
#
# Produção (pill.josoesantos.dev): use o domínio HTTPS — o Caddy termina TLS
# e o nginx do frontend encaminha /api ao backend.
VITE_ESP_BACKEND_URL=https://pill.josoesantos.dev
#
# Alternativa (API direta, sem passar pelo Caddy):
# VITE_ESP_BACKEND_URL=http://SEU_SERVIDOR:8001
